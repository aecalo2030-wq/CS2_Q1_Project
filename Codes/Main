# UPDATED CODE V4.1.1 - Now with Discount System
import json
import os
from datetime import datetime

# FILE HANDLING FEATURES
FILE_NAME = "inventory.json"

def save_data(inventory):
    """Save inventory to a JSON file"""
    with open(FILE_NAME, "w") as f:
        json.dump(inventory, f, indent=4)

def load_data():
    """Load inventory from file on startup"""
    if os.path.exists(FILE_NAME):
        with open(FILE_NAME, "r") as f:
            return json.load(f)
    return []

# --- HELPER FUNCTIONS ---

def get_valid_num(prompt, num_type=int):
    while True:
        try:
            val = num_type(input(prompt))
            if val < 0:
                print("Value cannot be negative.")
                continue
            return val
        except ValueError:
            print(f"Invalid input. Please enter a valid {num_type.__name__}.")

def choose_category(inventory):
    """Allow user to choose an existing category or add a new one"""
    categories = sorted(set(item["category"] for item in inventory))

    if categories:
        print("\nAvailable Categories:")
        for i, cat in enumerate(categories, 1):
            print(f"{i}. {cat}")
    else:
        print("\nNo categories yet.")

    print("0. Add New Category")
    choice = input("Choose category number: ")

    if choice == "0":
        return input("Enter new category name: ").strip().capitalize()

    try:
        choice = int(choice)
        return categories[choice - 1]
    except:
        print("Invalid choice. Creating new category.")
        return input("Enter new category name: ").strip().capitalize()

def manage_discounts(inventory):
    """Apply a percentage discount to an item"""
    name = input("\nWhich item are you discounting? ").strip().capitalize()
    
    for item in inventory:
        if item["name"] == name:
            print(f"Current Price: ₱{item['price']:.2f} | Current Discount: {item.get('discount', 0)}%")
            new_discount = get_valid_num(f"Enter new discount % for {name} (0-100): ", float)
            
            if new_discount > 100:
                print("Discount cannot exceed 100%!")
                return
                
            item["discount"] = new_discount
            save_data(inventory)
            discounted_price = item['price'] * (1 - item['discount']/100)
            print(f"Update successful! New selling price: ₱{discounted_price:.2f}")
            return

    print("Item not found.")

# CORE

def add_item(inventory):
    name = input("\nEnter item name: ").strip().capitalize()

    for item in inventory:
        if item["name"] == name:
            print(f"Item '{name}' already exists! Use the Restock option instead.")
            return

    category = choose_category(inventory)
    price = get_valid_num(f"Enter price of {name}: ₱", float)
    stock = get_valid_num("Enter starting stock: ", int)

    inventory.append({
        "name": name,
        "category": category,
        "price": price,
        "stock": stock,
        "sold": 0,
        "discount": 0.0, # Initialized discount
        "last_sale": "Never"
    })

    save_data(inventory)
    print(f"{name} added successfully!")

def sell_item(inventory):
    search_name = input("\nItem being sold: ").strip().capitalize()

    for item in inventory:
        if item["name"] == search_name:
            if item["stock"] <= 0:
                print("Out of stock!")
                return

            quantity = get_valid_num(f"Quantity (Available: {item['stock']}): ", int)

            if quantity > item["stock"]:
                print(f"Not enough stock! Selling remaining {item['stock']} units.")
                quantity = item["stock"]

            # Calculate discounted price
            current_discount = item.get("discount", 0)
            unit_price = item["price"] * (1 - current_discount / 100)
            total_sale = quantity * unit_price

            item["stock"] -= quantity
            item["sold"] += quantity
            item["last_sale"] = datetime.now().strftime("%Y-%m-%d %H:%M:%S")

            save_data(inventory)

            print(f"Sale recorded: ₱{total_sale:.2f}")
            if current_discount > 0:
                print(f"(Discount applied: {current_discount}%)")
            return

    print("Item not found.")

def show_report(inventory):
    if not inventory:
        print("\n[ Inventory is empty ]")
        return

    print("\n" + "="*115)
    print(f"{'ITEM NAME':<15} | {'PRICE':<10} | {'DISC%':<6} | {'SOLD':<6} | {'STOCK':<8} | {'LAST SALE':<20} | {'REVENUE'}")
    print("-" * 115)

    total_revenue = 0

    for item in inventory:
        # Calculate revenue based on discounted price at time of sale is complex; 
        # for this report, we show potential revenue of items already sold.
        discount_rate = item.get("discount", 0)
        current_price = item["price"] * (1 - discount_rate / 100)
        item_revenue = item["sold"] * current_price
        total_revenue += item_revenue

        status = "!" if item["stock"] <= 5 else " "

        print(f"{item['name']:<15} | ₱{item['price']:<9.2f} | {discount_rate:<6.1f} | {item['sold']:<6} | {item['stock']:<8}{status} | {item['last_sale']:<20} | ₱{item_revenue:.2f}")

    print("-" * 115)
    print(f"ESTIMATED TOTAL REVENUE: ₱{total_revenue:.2f}")
    print("(Note: Revenue is calculated based on current active discounts.)")
    print("="*115)

def restock_item(inventory):
    name = input("\nWhich item are you restocking? ").strip().capitalize()
    for item in inventory:
        if item["name"] == name:
            amount = get_valid_num(f"How many units of {name} are you adding? ", int)
            item["stock"] += amount
            save_data(inventory)
            print(f"Stock updated. New total: {item['stock']}")
            return
    print("Item not found.")

def delete_item(inventory):
    name = input("\nEnter item name to DELETE: ").strip().capitalize()
    for i, item in enumerate(inventory):
        if item["name"] == name:
            confirm = input(f"Are you sure you want to delete {name}? (y/n): ").lower()
            if confirm == 'y':
                inventory.pop(i)
                save_data(inventory)
                print(f"{name} removed from system.")
                return
    print("Item not found.")

# Main Code

def main():
    inventory = load_data()

    while True:
        print("\n--- MINI STORE V4.1.1 ---")
        print("1. Record Sale      4. Restock Item")
        print("2. View Report      5. Delete Item")
        print("3. Add New Item     6. Set Discounts")
        print("7. Exit")

        choice = input("\nSelect Option: ")

        if choice == '1':
            sell_item(inventory)
        elif choice == '2':
            show_report(inventory)
        elif choice == '3':
            add_item(inventory)
        elif choice == '4':
            restock_item(inventory)
        elif choice == '5':
            delete_item(inventory)
        elif choice == '6':
            manage_discounts(inventory)
        elif choice == '7':
            print("System offline. Have a great day!")
            break
        else:
            print("Invalid input.")

if __name__ == "__main__":
    main()
